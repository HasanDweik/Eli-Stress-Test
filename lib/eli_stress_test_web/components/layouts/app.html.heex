<div class="min-h-screen bg-slate-900">
  <header class="bg-slate-800 border-b border-slate-700 px-6 py-4">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-white">Eli Stress Test</h1>
          <p class="text-slate-400 text-sm">Load Testing Tool for APIs</p>
        </div>
        <div class="flex items-center space-x-4">
          <div class="text-right">
            <p class="text-xs text-slate-400">Status</p>
            <p class="text-sm font-semibold text-green-400">Ready</p>
          </div>
        </div>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto p-6">
    <%= @inner_content %>
  </main>

  <footer class="bg-slate-800 border-t border-slate-700 mt-12 py-4 px-6">
    <div class="max-w-7xl mx-auto text-center text-slate-400 text-sm">
      <p>Eli Stress Test v0.1.0 | MIT License</p>
    </div>
  </footer>
</div>
