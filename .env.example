# Environment Configuration
# Copy this file to .env and update with your specific values

# Application Environment
APP_ENV=dev
LOG_LEVEL=info

# API Configuration
API_BASE_URL=http://localhost:4000
API_TIMEOUT_MS=5000

# Test Configuration
DEFAULT_WORKERS=5
DEFAULT_REQUESTS=100

# Authentication (Optional)
BEARER_TOKEN=
API_KEY=

# SSL/TLS
SSL_VERIFY=true
